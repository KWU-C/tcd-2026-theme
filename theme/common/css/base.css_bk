/* layout  /////////////////////////////*/
#mainContents .t_center { text-align: center;}


/*==========================================
 共通スクロールフェード
===========================================*/
.fade_off {
  opacity: 0;
  transform: translateY(70px);
  transition: all 1.8s;
}
.fade_on {
  opacity: 1;
  transform: translateY(0px);
}


