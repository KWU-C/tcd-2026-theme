#mainContents .linkTyp01 a {
  position: relative;
  display: block;
  width: 210px;
  height: 60px;
  margin: 0 auto;
  padding: 10px 0 0 20px;
  box-sizing: border-box;
  border: 1px solid #323232;
  background-color: #FFF;
  font-family: 'Montserrat', sans-serif;
  font-size: 4.0rem;
  font-weight: 100;
  color: #323232;
  transition: all 0.3s;
}
